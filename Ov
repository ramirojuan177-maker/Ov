-- ==========================================================
-- LÓGICA DE NEGOCIO
-- ==========================================================

function applyObject(data, slot)
    local bs = raknetNewBitStream()
    raknetBitStreamWriteInt16(bs, select(2, sampGetPlayerIdByCharHandle(PLAYER_PED)))
    raknetBitStreamWriteInt32(bs, slot) 
    raknetBitStreamWriteBool(bs, true)
    raknetBitStreamWriteInt32(bs, data.modelId)
    raknetBitStreamWriteInt32(bs, 1) 
    raknetBitStreamWriteFloat(bs, data.offX)
    raknetBitStreamWriteFloat(bs, data.offY)
    raknetBitStreamWriteFloat(bs, data.offZ)
    raknetBitStreamWriteFloat(bs, data.rotX)
    raknetBitStreamWriteFloat(bs, data.rotY)
    raknetBitStreamWriteFloat(bs, data.rotZ)
    raknetBitStreamWriteFloat(bs, data.sclX)
    raknetBitStreamWriteFloat(bs, data.sclY)
    raknetBitStreamWriteFloat(bs, data.sclZ)
    raknetBitStreamWriteInt32(bs, -1)
    raknetBitStreamWriteInt32(bs, -1)
    raknetEmulRpcReceiveBitStream(113, bs)
    raknetDeleteBitStream(bs)
end

function clearVest(slot)
    local bs = raknetNewBitStream()
    raknetBitStreamWriteInt16(bs, select(2, sampGetPlayerIdByCharHandle(PLAYER_PED)))
    raknetBitStreamWriteInt32(bs, slot)
    raknetBitStreamWriteBool(bs, false)
    raknetEmulRpcReceiveBitStream(113, bs)
    raknetDeleteBitStream(bs)
end

function applyAll()
    if not sampIsLocalPlayerSpawned() then return end
    if totem_on[0] then applyObject(q.totem, 1) else clearVest(1) end
    if loro_on[0] then applyObject(q.loro, 2) else clearVest(2) end
    if katana_on[0] then applyObject(q.katana, 3) else clearVest(3) end
    if katana2_on[0] then applyObject(q.katana2, 4) else clearVest(4) end
end

function getTargetTable()
    if edit_target[0] == 1 then return q.totem
    elseif edit_target[0] == 2 then return q.loro
    elseif edit_target[0] == 3 then return q.katana
    elseif edit_target[0] == 4 then return q.katana2 end
    return q.totem
end

function syncSliders()
    local data = getTargetTable()
    editOff[1][0], editOff[2][0], editOff[3][0] = data.offX, data.offY, data.offZ
    editRot[1][0], editRot[2][0], editRot[3][0] = data.rotX, data.rotY, data.rotZ
    editScl[1][0], editScl[2][0], editScl[3][0] = data.sclX, data.sclY, data.sclZ
end

