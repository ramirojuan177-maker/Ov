function main()
    while not isSampAvailable() do wait(100) end
    syncSliders()
    sampRegisterChatCommand("ov", function() renderWindow[0] = not renderWindow[0] end)
    
    lua_thread.create(function()
        wait(2000)
        applyAll()
    end)

    while true do
        wait(0)
        m.Process = renderWindow[0]
    end
end
