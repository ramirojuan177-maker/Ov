local function CloseButton(str_id, value, size, rounding)
    size = size or 23; rounding = rounding or 50
    local DL = m.GetWindowDrawList()
    local p = m.GetCursorScreenPos()
    local result = m.InvisibleButton(str_id, m.ImVec2(size, size))
    if result then value[0] = false end
    local hovered = m.IsItemHovered()
    local col = m.ColorConvertFloat4ToU32(m.GetStyle().Colors[m.Col.Border])
    local col_bg = hovered and 0x60000000 or 0x30000000
    local offs = (size / 4)
    DL:AddRectFilled(p, m.ImVec2(p.x + size, p.y + size), col_bg, rounding, 15)
    DL:AddLine(m.ImVec2(p.x + offs, p.y + offs), m.ImVec2(p.x + size - offs, p.y + size - offs), col, size / 10)
    DL:AddLine(m.ImVec2(p.x + size - offs, p.y + offs), m.ImVec2(p.x + offs, p.y + size - offs), col, size / 10)
    return result
end

function m.BeginTitleChild(title, size, rounding, offset, panelBool)
    if panelBool == nil then panelBool = true end
    offset = offset or 50
    local DL = m.GetWindowDrawList()
    local posS = m.GetCursorScreenPos()
    local sizeT = m.CalcTextSize(title)
    m.PushStyleColor(m.Col.ChildBg, m.ImVec4(0, 0, 0, 0))
    m.PushStyleColor(m.Col.Border, m.ImVec4(0, 0, 0, 0))
    m.BeginChild(title.."##child", size, true, m.WindowFlags.NoScrollbar)
    if panelBool then m.SetCursorPos(m.ImVec2(10, 35)) end
    m.Spacing()
    m.PopStyleColor(2)
    DL:AddRect(posS, m.ImVec2(posS.x + size.x, posS.y + size.y), m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.Button]), rounding, nil, 2)
    if panelBool then
        DL:AddRectFilled(posS, m.ImVec2(posS.x + size.x, posS.y + 25), m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.Button]), rounding, 1+2)
        DL:AddText(m.ImVec2(posS.x + offset, posS.y + 12 - (sizeT.y / 2)), m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.Text]), title)
    end
end

function m.CustomMenu(labels, selected, size)
    local draw_list = m.GetWindowDrawList()
    for i, v in ipairs(labels) do
        local cPos = m.GetCursorPos()
        local p = m.GetCursorScreenPos()
        if m.InvisibleButton(v..'##'..i, size) then selected[0] = i end
        local isSelected = (selected[0] == i)
        if isSelected then
            draw_list:AddRectFilledMultiColor(m.ImVec2(p.x, p.y), m.ImVec2(p.x + size.x, p.y + size.y), m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.Button]), 0, 0, m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.Button]))
        end
        m.SetCursorPos(m.ImVec2(cPos.x + 15, cPos.y + (size.y - m.CalcTextSize(v).y) / 2))
        m.TextColored(isSelected and m.GetStyle().Colors[m.Col.ButtonHovered] or m.ImVec4(0.6, 0.6, 0.6, 0.6), v)
        draw_list:AddRectFilled(p, m.ImVec2(p.x + 3.5, p.y + size.y), isSelected and m.GetColorU32Vec4(m.GetStyle().Colors[m.Col.ButtonHovered]) or 0)
        m.SetCursorPos(m.ImVec2(cPos.x, cPos.y + size.y))
    end
end

